<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'QUALITY Fashion Store' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header class="shadow-sm bg-white sticky-top">
    <div class="bg-black text-white py-1 small">
        <div class="container d-flex justify-content-end align-items-center">
            <% if (session && session.MaNguoiDung) { %>
                <span class="me-3">Xin chào, <strong><%= session.HoVaTen %></strong></span>
                <a href="/dangxuat" class="text-white text-decoration-none"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a>
            <% } else { %>
                <a href="/dangky" class="text-white text-decoration-none me-3">Đăng ký</a>
                <a href="/dangnhap" class="text-white text-decoration-none">Đăng nhập</a>
            <% } %>
        </div>
    </div>
    <nav class="navbar navbar-expand-lg navbar-light py-2">
        <div class="container d-flex align-items-center">
            <div class="header-left">
                <a class="navbar-brand m-0" href="/">
                    <img src="/images/Quality_Logo.jpg" alt="QUALITY Logo" class="header-logo">
                </a>
            </div>
            <div class="collapse navbar-collapse header-center" id="navbarNav">
                <ul class="navbar-nav fw-bold text-uppercase gap-3">
                    <li class="nav-item">
                        <a class="nav-link <%= title.includes('Trang chủ') ? 'active-page' : '' %>" href="/">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title.includes('Sản phẩm') ? 'active-page' : '' %>" href="/sanpham">Sản phẩm</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title.includes('Chăm sóc') ? 'active-page' : '' %>" href="/cskh">CSKH</a>
                    </li>
                    <% if (session && [1, 3].includes(session.QuyenHan)) { %>
                        <li class="nav-item">
                            <a class="nav-link text-danger <%= title.includes('Quản lý') ? 'active-page' : '' %>" href="/admin">
                                <i class="bi bi-gear-fill me-1"></i>Quản lý
                            </a>
                        </li>
                    <% } %>
                </ul>
            </div>
            <div class="header-right-icons align-items-center">
                <a href="/giohang" class="text-dark position-relative" title="Giỏ hàng"><i class="bi bi-cart3 fs-5"></i></a>
                <% if (session && session.MaNguoiDung) { %>
                    <a href="/donhang" class="text-dark" title="Đơn hàng của tôi"><i class="bi bi-bag-check fs-5"></i></a>
                <% } %>
                <a href="/taikhoan" class="text-dark" title="Tài khoản"><i class="bi bi-person fs-5"></i></a>
               <a href="javascript:void(0)" class="text-dark" title="Hỗ trợ" id="btn-header-chat">
                    <i class="bi bi-chat-dots fs-5"></i>
                </a>
                <button class="navbar-toggler p-0 border-0 ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
        </div>
    </nav>
    <div class="scrolling-banner">
        <div class="scrolling-text">★ Chào mừng bạn đến với Quality Fashion - Phong cách dẫn đầu xu hướng ★</div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</header>