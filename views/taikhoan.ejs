<%- include('header') %>
<main class="account-wrapper mx-auto" id="main-account" style="max-width: 500px;">
    <h2 class="text-center fw-bold text-uppercase mb-5">Tài khoản của tôi</h2>

    <% if (typeof message !== 'undefined' && message) { %>
    <div id="msg-data" 
         data-content="<%= message %>" 
         data-type="<%= message.includes('thành công') ? 'success' : 'error' %>">
    </div>
    <% } %>

    <div class="account-card" id="info-section">
        <h4>Thông tin cá nhân</h4>
        <form action="/taikhoan/capnhat" method="POST">
            <div class="checkout-form-group">
                <label class="checkout-label">Tên đăng nhập</label>
                <input type="text" value="<%= user.TenDangNhap %>" disabled class="checkout-input disabled-input">
            </div>
            <div class="checkout-form-group">
                <label class="checkout-label">Họ và tên</label>
                <input type="text" name="HoTen" value="<%= user.HoTen %>" required class="checkout-input">
            </div>
            <div class="checkout-form-group">
                <label class="checkout-label">Email</label>
                <input type="email" name="Email" value="<%= user.Email || '' %>" class="checkout-input">
            </div>
            <div class="checkout-form-group">
                <label class="checkout-label">Số điện thoại</label>
                <input type="text" name="DienThoai" value="<%= user.DienThoai || '' %>" required class="checkout-input">
            </div>
            <div class="checkout-form-group">
                <label class="checkout-label">Địa chỉ mặc định</label>
                <textarea name="DiaChi" rows="2" class="checkout-input"><%= user.DiaChi || '' %></textarea>
            </div>
            <button type="submit" class="checkout-btn mt-2">Cập nhật thông tin</button>
        </form>

        <div class="text-center mt-4 border-top pt-3">
            <button type="button" id="btn-show-pwd" class="btn-link-gray">
                <i class="bi bi-key-fill"></i> Bạn muốn đổi mật khẩu?
            </button>
        </div>
    </div>

    <div class="account-card" id="password-section" style="display: none;">
        <h4>Đổi mật khẩu</h4>
        <form action="/taikhoan/doimatkhau" method="POST">
            <div class="checkout-form-group">
                <label class="checkout-label">Mật khẩu hiện tại <span class="text-red">*</span></label>
                <input type="password" name="MatKhauCu" required class="checkout-input" placeholder="Nhập mật khẩu cũ">
            </div>
            <div class="checkout-form-group">
                <label class="checkout-label">Mật khẩu mới <span class="text-red">*</span></label>
                <input type="password" name="MatKhauMoi" required class="checkout-input" placeholder="Mật khẩu từ 3 ký tự trở lên">
            </div>
            <div class="checkout-form-group">
                <label class="checkout-label">Xác nhận mật khẩu mới <span class="text-red">*</span></label>
                <input type="password" name="XacNhanMatKhau" required class="checkout-input" placeholder="Nhập lại mật khẩu mới">
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="button" id="btn-cancel-pwd" class="checkout-btn bg-white text-dark border flex-grow-1">Hủy</button>
                <button type="submit" class="checkout-btn flex-grow-1 bg-dark">Lưu mật khẩu mới</button>
            </div>
        </form>
    </div>

</main>
<%- include('footer') %>