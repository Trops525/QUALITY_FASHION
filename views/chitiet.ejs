<%- include('header') %>
<div class="bg-light-gray py-5 min-vh-100">
    <div class="product-detail-container">
        <% if (sanpham) { 
            // 1. Tính giá bán sau giảm giá
            let giaBan = sanpham.donGia - (sanpham.donGia * (sanpham.tiLeGiamGia || 0) / 100);
            
            let mangBienThe = sanpham.bienThe ;
            let sizes = [...new Set(mangBienThe.map(b => b.kichThuoc))]; 

            // 3. Xử lý đường dẫn ảnh 
            let anhChinh = sanpham.hinhAnh || '/images/default.jpg';
        %>
        <div class="d-flex flex-wrap gap-5">
            <div class="product-image-box">
                <img src="<%= anhChinh %>" alt="<%= sanpham.tenSanPham %>" class="w-100 object-fit-contain" style="max-width: 400px; border-radius: 8px;">
            </div>
            <div class="product-info-box">
                <h2 class="product-title-detail"><%= sanpham.tenSanPham %></h2>
                <p class="text-secondary font-13 mb-3">Mã sản phẩm: <%= sanpham.maSanPham %></p>
                <div class="product-meta-panel">
                    <div>Danh mục: <strong><%= sanpham.idDanhMuc ? (sanpham.idDanhMuc.TenDanhMuc || 'Chưa rõ') : 'Chưa rõ' %></strong></div>
                    <div class="mt-1">Đã bán: <strong><%= sanpham.luotMua || 0 %></strong></div>
                </div>
                <h3 class="product-price-detail"><%= giaBan.toLocaleString('vi-VN') %>đ</h3>
                
                <form action="/giohang/them" method="POST">
                    <input type="hidden" name="idSanPham" value="<%= sanpham._id %>">
                    <input type="hidden" name="mauSac" value="<%= mangBienThe.length > 0 ? mangBienThe[0].mauSac : sanpham.tenSanPham.split(' ').pop() %>">
                    
                    <div class="mb-4">
                        <label class="fw-bold font-13 d-block mb-2">Màu sắc hiện có:</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <% if (typeof listMauSac !== 'undefined' && listMauSac.length > 0) { %>
                                <% listMauSac.forEach(item => { %>
                                    <a href="<%= item.hetHang ? 'javascript:void(0)' : '/sanpham/chitiet/' + item.id %>" class="text-decoration-none <%= item.hetHang ? 'disabled-variant' : '' %>" title="<%= item.hetHang ? 'Màu này đã hết hàng' : item.mauSac %>">
                                        <span class="btn-select <%= item.isActive ? 'active' : 'dashed' %>" style="position: relative;"><%= item.mauSac %></span>
                                    </a>
                                <% }) %>
                            <% } else { %>
                                <% let mauSacUnique = [...new Set(mangBienThe.map(b => b.mauSac))]; %>
                                <% if (mauSacUnique.length > 0) { %>
                                    <% mauSacUnique.forEach(m => { %>
                                        <span class="btn-select active"><%= m %></span>
                                    <% }) %>
                                <% } else { %>
                                    <span class="btn-select active">Mặc định</span>
                                <% } %>
                            <% } %>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="fw-bold font-13 d-block mb-2">Kích thước:</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <% if (sizes.length > 0) { %>
                                <% 
                                    let firstAvailableIndex = sizes.findIndex(s => {
                                        let v = mangBienThe.find(b => b.kichThuoc === s);
                                        return v && v.soLuong > 0;
                                    });
                                    sizes.forEach((s, index) => { 
                                        let variant = mangBienThe.find(b => b.kichThuoc === s);
                                        let outOfStock = !variant || variant.soLuong <= 0;
                                        let isChecked = index === firstAvailableIndex;
                                %>
                                    <label class="cursor-pointer m-0 <%= outOfStock ? 'disabled-variant' : '' %>" title="<%= outOfStock ? 'Hết hàng' : 'Còn ' + (variant ? variant.soLuong : 0) + ' sản phẩm' %>">
                                        <input type="radio" name="kichThuoc" value="<%= s %>" <%= isChecked ? 'checked' : '' %> <%= outOfStock ? 'disabled' : '' %> class="d-none radio-size" required>
                                        <span class="btn-select size-btn <%= isChecked ? 'active' : '' %>" style="position: relative;"><%= s %></span>
                                    </label>
                                <% }) %>
                            <% } else { %>
                                <span class="text-muted font-13">Liên hệ shop để biết kích cỡ</span>
                            <% } %>
                        </div>
                    </div>

                    <% 
                        let firstAvail = sizes.findIndex(s => {
                            let v = mangBienThe.find(b => b.kichThuoc === s);
                            return v && v.soLuong > 0;
                        });
                        let hetSachHang = firstAvail === -1;
                    %>
                    <div class="d-flex gap-3 mb-3">
                        <button type="submit" name="action" value="add" class="btn-add-cart-outline" <%= hetSachHang ? 'disabled style="cursor:not-allowed; opacity:0.6"' : '' %>><%= hetSachHang ? 'HẾT HÀNG' : 'THÊM VÀO GIỎ HÀNG' %></button>
                        <button type="submit" name="action" value="buy" class="btn-buy-now" <%= hetSachHang ? 'disabled style="cursor:not-allowed; opacity:0.6"' : '' %>><%= hetSachHang ? 'HẾT HÀNG' : 'MUA NGAY' %></button>
                    </div>
                    <a href="/sanpham" class="text-secondary font-13 text-decoration-none">← Tiếp tục mua sắm sản phẩm </a>
                </form>
            </div>
        </div>

        <hr class="my-5 opacity-25">

        <div class="text-center mb-5" id="danh-gia">
            <h4 class="fw-bold text-uppercase font-15 mb-4 ls-1">ĐÁNH GIÁ SẢN PHẨM</h4>
            
            <!-- Danh sách đánh giá -->
            <div class="text-start mx-auto" style="max-width: 600px;">
                <% if (sanpham.danhGia && sanpham.danhGia.length > 0) { %>
                    <% sanpham.danhGia.forEach(dg => { %>
                        <div class="mb-3 p-3 border rounded bg-white">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong class="font-14"><%= dg.tenNguoiDung %></strong>
                                <small class="text-muted"><%= new Date(dg.ngayDanhGia).toLocaleDateString('vi-VN') %></small>
                            </div>
                            <div class="text-warning mb-2">
                                <% for(let i=0; i<5; i++) { %>
                                    <i class="bi <%= i < dg.soSao ? 'bi-star-fill' : 'bi-star' %>"></i>
                                <% } %>
                            </div>
                            <p class="mb-0 font-14"><%= dg.noiDung %></p>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-muted font-13 fst-italic text-center">Chưa có đánh giá nào cho sản phẩm này.</p>
                <% } %>
            </div>

            <!-- Form đánh giá -->
            <% if (typeof canReview !== 'undefined' && canReview) { %>
                <div class="mx-auto mt-4 text-start" style="max-width: 600px;">
                    <form action="/sanpham/chitiet/<%= sanpham._id %>/danhgia" method="POST" class="p-4 border rounded bg-light">
                        <h6 class="fw-bold mb-3">Viết đánh giá của bạn</h6>
                        <div class="mb-3">
                            <label class="form-label font-13 fw-bold">Số sao:</label>
                            <select name="soSao" class="form-select form-select-sm w-auto d-inline-block">
                                <option value="5">5 Sao (Rất tốt)</option>
                                <option value="4">4 Sao (Tốt)</option>
                                <option value="3">3 Sao (Bình thường)</option>
                                <option value="2">2 Sao (Kém)</option>
                                <option value="1">1 Sao (Rất kém)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label font-13 fw-bold">Nội dung đánh giá:</label>
                            <textarea name="noiDung" class="form-control" rows="3" required placeholder="Nhập đánh giá của bạn về sản phẩm..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-dark btn-sm fw-bold px-4">Gửi đánh giá</button>
                    </form>
                </div>
            <% } else { %>
                <p class="font-13 mt-4 text-center">
                    <% if (typeof reasonCantReview !== 'undefined' && typeof session !== 'undefined' && session.MaNguoiDung) { %>
                        <span class="text-muted"><%= reasonCantReview %></span>
                    <% } else { %>
                        Vui lòng <a href="/dangnhap" class="text-dark fw-bold text-decoration-none">đăng nhập</a> để đánh giá.
                    <% } %>
                </p>
            <% } %>
        </div>

        <hr class="my-5 opacity-25">

        <div class="text-center">
            <h4 class="fw-bold text-uppercase font-15 mb-4 ls-1">GỢI Ý SẢN PHẨM</h4>
            <div class="product-grid-4" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px;">
                <% if (typeof sanphamGoiY !== 'undefined' && sanphamGoiY.length > 0) {
                    sanphamGoiY.forEach(sp => {
                        let giaGoiY = sp.donGia - (sp.donGia * (sp.tiLeGiamGia || 0) / 100);
                        let anhGoiY = sp.hinhAnh || '/images/default.jpg';
                %>
                <div class="product-item-card text-start" style="border: 1px solid #eee; border-radius: 8px; overflow: hidden;">
                    <a href="/sanpham/chitiet/<%= sp._id %>" class="text-decoration-none text-dark d-block">
                        <img src="<%= anhGoiY %>" alt="<%= sp.tenSanPham %>" class="w-100 product-img-thumb bg-light" style="height: 220px; object-fit: cover;">
                        <div class="p-3">
                            <h6 class="product-title-grid" style="font-size: 14px; margin-bottom: 5px; height: 35px; overflow: hidden;"><%= sp.tenSanPham %></h6>
                            <p class="text-danger fw-bold font-14 m-0"><%= giaGoiY.toLocaleString('vi-VN') %>đ</p>
                        </div>
                    </a>
                </div>
                <% })} else { %>
                    <p class="grid-span-4 text-muted font-13 fst-italic py-4 w-100">Chưa có sản phẩm gợi ý nào.</p>
                <% } %>
            </div>
        </div>

        <% } else { %>
            <div class="text-center py-5">
                <h3 class="text-muted">Rất tiếc, không tìm thấy sản phẩm!</h3>
                <p>Vui lòng kiểm tra lại đường dẫn hoặc quay lại trang chủ.</p>
                <a href="/sanpham" class="btn btn-primary mt-3">Quay lại cửa hàng</a>
            </div>
        <% } %>
    </div>
</div>
<%- include('footer') %>