<%- include('header') %>
<div class="container py-5 max-width-1100">
    <h2 class="text-center text-uppercase fw-bold mb-5">Thanh toán</h2>
    
    <div class="checkout-grid">
        <div class="checkout-section">
            <form action="/thanhtoan" method="POST">
                <input type="hidden" name="checkout_type" value="<%= type %>">
                <div class="checkout-form-group">
                    <label class="checkout-label">Họ và tên</label>
                    <input type="text" value="<%= user.HoTen %>" disabled class="checkout-input disabled-input">
                </div>
                <div class="checkout-form-group">
                    <label class="checkout-label">Địa chỉ nhận hàng <span class="text-red">*</span></label>
                    <input type="text" name="diaChi" value="<%= user.DiaChi %>" required class="checkout-input" placeholder="Số nhà, Tên đường, Quận/Huyện...">
                </div>
                <div class="checkout-form-group">
                    <label class="checkout-label">Số điện thoại <span class="text-red">*</span></label>
                    <input type="text" name="dienThoai" value="<%= user.DienThoai %>" required class="checkout-input">
                </div>
                <div class="checkout-form-group">
                    <label class="checkout-label">Ghi chú (Tùy chọn)</label>
                    <textarea name="ghiChu" rows="2" class="checkout-input"></textarea>
                </div>
                <div class="checkout-form-group">
                    <label class="checkout-label">Phương thức thanh toán <span class="text-red">*</span></label>
                    <div class="checkout-payment-box">
                        <label class="payment-option"><input type="radio" name="phuongThuc" value="COD" checked> Thanh toán khi nhận hàng</label>
                        <label class="payment-option mt-3"><input type="radio" name="phuongThuc" value="BANK"> Chuyển khoản ngân hàng</label>
                    </div>
                </div>
                <button type="submit" class="checkout-btn">Xác nhận đặt hàng</button>
            </form>
        </div>

        <div class="checkout-section h-100">
            <h6 class="fw-bold mb-4 font-16 border-bottom pb-2">Đơn hàng của bạn</h6>
            <div class="checkout-scroll-area">
                <% items.forEach(item => { %>
                    <div class="checkout-summary-item">
                        <div class="d-flex align-items-center gap-3">
                            <img src="<%= item.hinhAnh %>" class="checkout-item-img">
                            <div>
                                <span class="d-block fw-bold mb-1 font-13"><%= item.ten %></span>
                                <small class="text-muted">Size: <%= item.kichThuoc %> | SL: <%= item.soLuong %></small>
                            </div>
                        </div>
                        <span class="fw-bold font-14"><%= item.thanhTien.toLocaleString('vi-VN') %>đ</span>
                    </div>
                <% }) %>
            </div>
            <div class="d-flex justify-content-between mt-4 pt-4 border-top">
                <span class="fw-bold fs-5">Tổng cộng:</span>
                <span class="fw-bold fs-5 text-red"><%= total.toLocaleString('vi-VN') %> đ</span>
            </div>
            <div id="qr-payment-container" class="qr-payment-box">
                <p class="fw-bold mb-2 font-14">Quét mã QR để thanh toán</p>
                <img src="/images/qr-payment.jpg" alt="QR" class="qr-img">
            </div>
        </div>
    </div>
</div>
<%- include('footer') %>