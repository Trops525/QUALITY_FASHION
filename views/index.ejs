<%- include('header') %>

<section class="banner-slider">
    <div class="slider-container h-100 w-100 position-absolute top-0 start-0">
        <% if (typeof banners !== 'undefined' && banners.length > 0) { %>
            <% banners.forEach(function(banner, index) { %>
                <div class="slide <%= index === 0 ? 'slide-active' : '' %> h-100 w-100">
                    <img src="<%= banner.hinhAnh %>" alt="Banner <%= index + 1 %>" class="img-fit">
                </div>
            <% }); %>
        <% } else { %>
            <div class="slide slide-active h-100 w-100"><img src="/images/banner1.jpg" alt="Banner 1" class="img-fit"></div>
            <div class="slide h-100 w-100"><img src="/images/banner2.jpg" alt="Banner 2" class="img-fit"></div>
            <div class="slide h-100 w-100"><img src="/images/banner3.jpg" alt="Banner 3" class="img-fit"></div>
            <div class="slide h-100 w-100"><img src="/images/banner4.jpg" alt="Banner 4" class="img-fit"></div>
        <% } %>
        
        <div class="slider-controls w-100 position-absolute top-50 start-0 translate-middle-y d-flex justify-content-between px-4 z-1">
            <button class="slider-btn" onclick="plusSlides(-1)"><i class="bi bi-chevron-left fs-5"></i></button>
            <button class="slider-btn" onclick="plusSlides(1)"><i class="bi bi-chevron-right fs-5"></i></button>
        </div>
    </div>
</section>

<div class="container max-width-1100 my-5">
    <div class="category-tabs text-center mb-5">
        <% 
            let qParam = query.q ? '&q=' + encodeURIComponent(query.q) : ''; 
        %>
        <div class="mb-4">
            <a href="/?gender=Nam<%= qParam %>" class="category-tab-btn <%= query.gender == 'Nam' ? 'active' : '' %>">NAM</a>
            <a href="/?gender=Unisex<%= qParam %>" class="category-tab-btn <%= query.gender == 'Unisex' ? 'active' : '' %>">PHỤ KIỆN</a>
            <a href="/?gender=Nữ<%= qParam %>" class="category-tab-btn <%= query.gender == 'Nữ' ? 'active' : '' %>">NỮ</a>
        </div>
        <h4 class="fw-bold text-uppercase ls-2 mb-2">CÁC SẢN PHẨM MỚI RA MẮT</h4>
        <div class="title-underline mx-auto"></div>
    </div>

    <div class="product-grid-4">
        <% if (sanpham && sanpham.length > 0) { %>
            <% sanpham.forEach(function(sp) { 
                let giaBan = sp.donGia - (sp.donGia * (sp.tiLeGiamGia || 0) / 100);
            %>
                <div class="product-item-card">
                    <a href="/sanpham/chitiet/<%= sp._id %>" class="text-decoration-none text-dark d-block">
                        <div class="position-relative">
                                <img src="<%= sp.hinhAnh || '/images/default.jpg' %>" alt="<%= sp.tenSanPham %>" class="w-100 product-img-thumb">                            <% if (sp.tiLeGiamGia > 0) { %>
                                <span class="badge-sale">-<%= sp.tiLeGiamGia %>%</span>
                            <% } %>
                        </div>
                        <div class="p-3 text-center">
                            <div class="product-title-grid"><%= sp.tenSanPham %></div>
                            <div class="text-danger fw-bold fs-6">
                                <% if (sp.tiLeGiamGia > 0) { %>
                                    <span class="text-muted text-decoration-line-through font-12 me-2"><%= sp.donGia.toLocaleString('vi-VN') %> đ</span>
                                    <span><%= giaBan.toLocaleString('vi-VN') %> đ</span>
                                <% } else { %>
                                    <span><%= sp.donGia.toLocaleString('vi-VN') %> đ</span>
                                <% } %>
                            </div>
                        </div>
                    </a>
                </div>
            <% }); %>
        <% } else { %>
            <p class="text-center grid-span-4 py-5 text-secondary">Hiện tại chưa có sản phẩm nào cho mục này.</p>
        <% } %>
    </div>
    <% 
        let queryParams = '?page=PAGE';
        if (query.gender) queryParams += '&gender=' + encodeURIComponent(query.gender);
        if (query.q) queryParams += '&q=' + encodeURIComponent(query.q);
    %>
    <%- include('pagination', { pagType: 'link', queryParams: queryParams, currentPage: currentPage, totalPages: totalPages }) %>
</div>
<%- include('footer') %>