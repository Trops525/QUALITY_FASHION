<%- include('header') %>
<main class="cart-page-wrapper">
    <div class="container">
        <h1 class="mb-4">Giỏ hàng của bạn</h1>
        <% if (!cartItems || cartItems.length === 0) { %>
            <div class="cart-empty"><p class="mb-3">Giỏ hàng trống.</p><a href="/sanpham" class="btn-black">Mua ngay</a></div>
        <% } else { %>
            <form method="POST" action="/giohang/capnhat" id="cart-form">
                <div class="cart-table-container">
                    <table class="cart-table">
                        <thead>
                            <tr>
                                <th class="text-center w-40"><input type="checkbox" id="check-all" checked class="cart-checkbox"></th>
                                <th>Ảnh</th>
                                <th>Sản phẩm</th>
                                <th class="text-center">Phân loại</th>
                                <th>Giá</th>
                                <th>SL</th>
                                <th>Tổng</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cartItems.forEach(item => { %>
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="selected_items[]" value="<%= item.cartKey %>" class="check-item cart-checkbox" data-price="<%= item.thanhTien %>" checked>
                                    </td>
                                    <td><img src="<%= item.hinhAnh || '/images/default.jpg' %>" class="cart-img"></td>
                                    <td><a href="/sanpham/chitiet/<%= item.id %>" class="cart-item-name"><%= item.ten %></a></td>
                                    <td class="text-center fw-bold font-13">Màu: <%= item.mauSac %><br>Size: <%= item.kichThuoc %></td>
                                    <td><%= item.donGia.toLocaleString('vi-VN') %> đ</td>
                                    <td><input type="number" name="quantities[<%= item.cartKey %>]" value="<%= item.soLuong %>" min="1" class="cart-qty-input"></td>
                                    <td class="text-red-bold"><%= item.thanhTien.toLocaleString('vi-VN') %> đ</td>
                                    <td><a href="/giohang/xoa/<%= item.cartKey %>" class="btn-delete-item" onclick="return confirm('Xóa?')">Xóa</a></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="cart-summary mt-4">
                    <div class="fs-5">Tổng tiền: <strong id="display-total" class="cart-total-value"><%= total.toLocaleString('vi-VN') %> đ</strong></div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-yellow">Cập nhật</button>
                        <a href="/thanhtoan" id="btn-checkout" class="btn-black">Thanh toán</a>
                    </div>
                </div>
            </form>
        <% } %>
    </div>
</main>
<%- include('footer') %>