<%- include('header') %>
<!-- Thêm dòng này nếu file header.ejs của bạn chưa nhúng admin.css -->
<link rel="stylesheet" href="/css/admin.css">

<div class="header-page">
    <h1>Thêm Người Dùng Mới</h1>
</div>

<div class="admin-form-container">
    <form action="/admin/nguoidung/them" method="POST" id="form-them-nguoi-dung">
        <div class="admin-form-group">
            <label class="admin-form-label">Họ và Tên <span class="text-danger">*</span></label>
            <input type="text" name="HoTen" required class="admin-form-input">
        </div>
        
        <div class="admin-form-group">
            <label class="admin-form-label">Tên Đăng Nhập <span class="text-danger">*</span></label>
            <input type="text" name="TenDangNhap" required minlength="4" class="admin-form-input">
        </div>

        <div class="admin-form-group">
            <label class="admin-form-label">Email <span class="text-danger">*</span></label>
            <input type="email" name="Email" required class="admin-form-input">
        </div>

        <div class="admin-form-group">
            <label class="admin-form-label">Số Điện Thoại <span class="text-danger">*</span></label>
            <input type="text" name="DienThoai" required pattern="[0-9]{10}" class="admin-form-input">
        </div>

        <div class="admin-form-group">
            <label class="admin-form-label">Mật Khẩu <span class="text-danger">*</span></label>
            <input type="password" name="MatKhau" required minlength="5" class="admin-form-input">
        </div>

        <div class="admin-form-group">
            <label class="admin-form-label">Xác Nhận Mật Khẩu <span class="text-danger">*</span></label>
            <input type="password" name="XacNhanMatKhau" required minlength="5" class="admin-form-input">
        </div>

        <div class="admin-form-group">
            <label class="admin-form-label">Phân Quyền</label>
            <select name="QuyenHan" class="admin-form-input">
                <option value="2">Khách hàng</option>
                <option value="3">Nhân viên</option>
                <option value="1">Quản trị (Admin)</option>
            </select>
        </div>

        <div class="admin-form-actions">
            <button type="submit" class="btn-admin-submit">Tạo Tài Khoản</button>
            <a href="/admin/nguoidung" class="btn-admin-cancel">Hủy Bỏ</a>
        </div>
    </form>
</div>

<%- include('footer') %>