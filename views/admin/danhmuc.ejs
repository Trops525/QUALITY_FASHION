<%- include('header') %>

<div class="header-page">
    <h1>Quản lý Danh mục</h1>
</div>

<!-- Form Thêm Danh Mục -->
<div class="dm-add-container">
    <form action="/admin/danhmuc/them" method="POST" class="dm-add-form">
        <div class="dm-input-group">
            <label>Thêm danh mục mới</label>
            <input type="text" name="ten_danh_muc" required placeholder="Nhập tên danh mục...">
        </div>
        <button type="submit" class="btn-dm-add">
            <i class="fa fa-plus"></i> Thêm danh mục
        </button>
    </form>
</div>

<div class="table-container">
    <table class="product-table">
        <thead>
            <tr>
                    <th class="text-center" style="width: 60px;">STT</th>
                    <th>Tên Danh Mục</th>
                    <th class="text-center" style="width: 150px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof danhSachDM !== 'undefined' && danhSachDM.length > 0) { %>
                    <% danhSachDM.forEach((dm, index) => { %>
                        <tr>
                            <td class="text-center"><%= index + 1 %></td>
                            <td><strong class="dm-name"><%= dm.TenDanhMuc || dm.tenDanhMuc %></strong></td>
                            <td class="text-center">
                                <div class="action-buttons text-center">
                                    <button type="button" class="btn-sm btn-dm-edit" 
                                            onclick="suaDanhMuc('<%= dm._id %>', '<%= dm.TenDanhMuc || dm.tenDanhMuc %>')">Sửa</button>
                                    <a href="/admin/danhmuc/xoa/<%= dm._id %>" class="btn-sm btn-delete" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này không?');">Xóa</a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="3" class="text-center text-muted" style="padding: 40px;">Chưa có danh mục nào.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
<%- include('footer') %>